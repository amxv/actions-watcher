{
  "name": "actions-watcher",
  "version": "0.1.0",
  "description": "Fail-fast watcher for GitHub Actions workflow runs",
  "license": "MIT",
  "author": "amxv",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amxv/actions-watcher.git"
  },
  "homepage": "https://github.com/amxv/actions-watcher#readme",
  "bugs": {
    "url": "https://github.com/amxv/actions-watcher/issues"
  },
  "bin": {
    "actions-watcher": "bin/actions-watcher.js"
  },
  "config": {
    "cliBinaryName": "actions-watcher"
  },
  "files": [
    "bin/actions-watcher.js",
    "scripts/postinstall.js",
    "cmd",
    "internal",
    "go.mod",
    "LICENSE",
    "README.md",
    "AGENTS.md",
    "CONTRIBUTORS.md",
    "Makefile"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "test": "node --check bin/actions-watcher.js && node --check scripts/postinstall.js",
    "lint": "npm run test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "github-actions",
    "watcher",
    "go",
    "cli",
    "fail-fast"
  ]
